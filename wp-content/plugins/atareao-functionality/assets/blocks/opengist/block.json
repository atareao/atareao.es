{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "atareao/opengist",
    "title": "OpenGist",
    "category": "embed",
    "icon": "editor-code",
    "description": "Embed un gist de OpenGist",
    "keywords": [
        "gist",
        "opengist",
        "code",
        "embed"
    ],
    "version": "1.0.0",
    "textdomain": "atareao-functionality",
    "supports": {
        "html": false,
        "align": [
            "wide",
            "full"
        ],
        "spacing": {
            "margin": true,
            "padding": true
        },
        "color": {
            "background": true,
            "text": true
        }
    },
    "attributes": {
        "server": {
            "type": "string",
            "default": ""
        },
        "username": {
            "type": "string",
            "default": ""
        },
        "gistId": {
            "type": "string",
            "default": ""
        },
        "file": {
            "type": "string",
            "default": ""
        },
        "theme": {
            "type": "string",
            "default": "auto"
        }
    }
}
